# LLM Chat Integration
# URL of the Vercel Edge proxy for OpenRouter
VITE_LLM_PROXY_URL=https://your-api.vercel.app/api/chat

# Clerk Authentication & Billing (optional — chat works without auth in free-tier mode)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# API proxy environment variables (set in Vercel project settings for apps/api)
# OPENROUTER_API_KEY=sk-or-...
# CLERK_SECRET_KEY=sk_test_...
# APP_URL=https://ifc-lite.com
