{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "noEmitOnError": false,
    "skipLibCheck": true,
    "paths": {
      "@ifc-lite/ifcx": [
        "../ifcx/src/index.ts"
      ],
      "@ifc-lite/ifcx/*": [
        "../ifcx/src/*"
      ]
    }
  },
  "include": ["src/**/*"]
}
