# LLM Chat Integration
# URL of the Vercel Edge proxy
VITE_LLM_PROXY_URL=https://your-api.vercel.app/api/chat

# Clerk Authentication & Billing (optional — chat works without auth in free-tier mode)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# API proxy environment variables (set in Vercel project settings for apps/api)
# LLM_API_KEY=sk-or-...
# LLM_API_BASE=https://openrouter.ai/api/v1
# CLERK_SECRET_KEY=sk_test_...
# APP_URL=https://ifc-lite.com

# ── Model configuration ──
# Comma-separated model IDs for each tier.
# LLM_FREE_MODELS=qwen/qwen3-coder:free,mistralai/devstral-2512:free,deepseek/deepseek-r1:free,meta-llama/llama-3.3-70b-instruct:free,openai/gpt-oss-120b:free
# LLM_PRO_MODELS=qwen/qwen3-coder,google/gemini-3-flash-preview,minimax/minimax-m2.1,z-ai/glm-4.7,x-ai/grok-code-fast-1,anthropic/claude-sonnet-4.5,anthropic/claude-sonnet-4.6,openai/gpt-5.2,x-ai/grok-4.1-fast,google/gemini-3-pro-preview,google/gemini-3.1-pro-preview,anthropic/claude-opus-4.5

# ── Usage limits ──
# Free tier: max requests per day
# LLM_FREE_DAILY_LIMIT=50
# Pro tier: monthly credit allowance (1 credit ≈ 1 unit of usage)
# LLM_PRO_MONTHLY_CREDITS=1000
# Conversion factor: multiply API cost by this to get credits consumed
# LLM_COST_TO_CREDITS=200
